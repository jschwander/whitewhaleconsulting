rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Blog images: public read; uploads only via Admin SDK on the server.
    match /blog/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
